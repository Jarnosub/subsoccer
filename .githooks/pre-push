#!/bin/bash
# =================================================================
# PRE-PUSH HOOK: Prevent direct pushes to main
# Forces all production deploys to go through staging → PR → main
# =================================================================

PROTECTED_BRANCH="main"
CURRENT_BRANCH=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

while read local_ref local_sha remote_ref remote_sha; do
    if echo "$remote_ref" | grep -q "refs/heads/$PROTECTED_BRANCH"; then
        echo ""
        echo "🚫 BLOCKED: Direct push to '$PROTECTED_BRANCH' is not allowed!"
        echo ""
        echo "   Production deploys must go through staging:"
        echo "   1. Push to 'staging' branch"
        echo "   2. Test on staging environment"
        echo "   3. Create a Pull Request: staging → main"
        echo "   4. Merge the PR on GitHub"
        echo ""
        echo "   To push to staging instead:"
        echo "   git push origin staging"
        echo ""
        echo "   ⚠️  To bypass (EMERGENCY ONLY):"
        echo "   git push origin main --no-verify"
        echo ""
        exit 1
    fi
done

exit 0
