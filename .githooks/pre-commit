#!/bin/sh
# Auto-bump version.js on every commit
# Uses date-based version: YYYY.MM.DD.HHMM

VERSION=$(date +"%Y.%m.%d.%H%M")

cat > version.js << EOF
// ─── Subsoccer Pro App Version ───
// AUTO-GENERATED by git pre-commit hook. Do not edit manually.
const APP_VERSION = '${VERSION}';
EOF

git add version.js
